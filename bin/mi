#!/usr/bin/env bash

[ "$#" -lt 2 ] && { echo "Prints the value of the first argument with the remaining arguments subtracted from it.
Usage: $0 <initial value> <number>..." >&2; exit 1; }

total=$1
shift
for n in "$@"; do
    total=$(echo "$total - $n" | bc -l)
done

echo "$total" | sed 's/\.0*$//;s/\(\.[0-9]*[1-9]\)0*$/\1/;s/^\./0./;s/^-\./-0./'
