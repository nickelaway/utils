#!/usr/bin/env bash

human=0
[ "$1" = "-h" ] && { human=1; shift; }

[ "$#" -lt 2 ] && { echo "Prints the sum of the arguments.
Usage: $0 [-h] <number> <number>..." >&2; exit 1; }

format_commas() {
    local num="$1" sign=""
    [[ "$num" == -* ]] && { sign="-"; num="${num#-}"; }
    local int="${num%%.*}" dec="${num#"${num%%.*}"}"
    int=$(echo "$int" | rev | sed 's/\([0-9]\{3\}\)/\1,/g;s/,$//' | rev)
    echo "${sign}${int}${dec}"
}

total=0
for n in "$@"; do
    n="${n//,/}"
    total=$(echo "$total + $n" | bc -l)
done

result=$(echo "$total" | sed 's/\.0*$//;s/\(\.[0-9]*[1-9]\)0*$/\1/;s/^\./0./;s/^-\./-0./')
[ "$human" -eq 1 ] && result=$(format_commas "$result")
echo "$result"
