#!/usr/bin/perl

use strict;
use warnings;
use POSIX qw(strftime);

my $readLine;
if (@ARGV) {
    $readLine = sub {return shift(@ARGV) . "\n" if(@ARGV)};
} else {
    $readLine = sub {return <STDIN>};
}

sub parseEpochTime {
    my $val = shift;
    my $sub = "";
    if(length($val) > 10) {
	    $sub="." . substr($val, 10);
    }
    return strftime("{%Y-%m-%d_%H:%M:%S$sub}",localtime(substr($val, 0, 10)));
}

while(my $line = $readLine->()) {
    $line =~ s/^((.*[^\d])?)(\d{19}|\d{13}|\d{10})([^\d].*)?$/"$1$3" . parseEpochTime($3) . "$4"/ge;
    print $line;
}
