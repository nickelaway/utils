#!/usr/bin/env bash

format_epoch() {
    local val="$1"
    local sec="${val:0:10}"
    local subsec=""
    [[ "${#val}" -gt 10 ]] && subsec=".${val:10}"

    local tz_suffix=""
    if [[ "$TZ_SPECIFIED" == true ]]; then
        local offset
        offset=$(TZ="$TZ" date -d "@$sec" "+%z")
        if [[ "$offset" == "+0000" ]]; then
            tz_suffix="Z"
        else
            tz_suffix="${offset:0:3}:${offset:3:2}"
        fi
    fi

    TZ="$TZ" date -d "@$sec" "+{%Y-%m-%d_%H:%M:%S${subsec}${tz_suffix}}"
}

process_line() {
    local remaining="$1"
    local result=""

    while [[ "$remaining" =~ ^([^0-9]*)([0-9]+)(.*)$ ]]; do
        local digits="${BASH_REMATCH[2]}"
        result+="${BASH_REMATCH[1]}"
        if [[ " ${LENGTHS[*]} " == *" ${#digits} "* ]]; then
            result+="${digits}$(format_epoch "$digits")"
        else
            result+="$digits"
        fi
        remaining="${BASH_REMATCH[3]}"
    done

    echo "${result}${remaining}"
}

LENGTHS=()
TZ="UTC"
TZ_SPECIFIED=false
while [[ "$1" == --* ]]; do
    case "$1" in
        --seconds)  LENGTHS+=(10) ;;
        --millis)   LENGTHS+=(13) ;;
        --nanos)    LENGTHS+=(19) ;;
        --tz=*)     TZ="${1#--tz=}"; TZ_SPECIFIED=true ;;
        --tz)       TZ="$2"; TZ_SPECIFIED=true; shift ;;
        *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
    shift
done
[[ "${#LENGTHS[@]}" -eq 0 ]] && LENGTHS=(10 13 19)

if [[ "$#" -gt 0 ]]; then
    for arg in "$@"; do
        process_line "$arg"
    done
else
    while IFS= read -r line; do
        process_line "$line"
    done
fi
